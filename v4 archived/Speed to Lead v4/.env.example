# Speed-to-Lead v4 — Environment Variables
# Copy this file to .env and fill in your values for local development.
# For production (Render), set these in the Render dashboard under Settings → Environment.

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (Render provides this automatically)
# Format: postgresql://user:password@host:port/database
# For local dev with SQLite, leave blank or use: sqlite:///./local.db
DATABASE_URL=postgresql://user:password@localhost:5432/speedtolead

# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════════

# "production" or "development" — controls logging, debug mode, etc.
ENVIRONMENT=development

# Public URL for webhooks (Twilio needs this to reach your app)
# For local dev: use ngrok (e.g. https://abc123.ngrok.io)
# For production: your Render URL (e.g. https://speed-to-lead.onrender.com)
PUBLIC_BASE_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════════════════════
# TWILIO (SMS & Voice)
# ═══════════════════════════════════════════════════════════════════════════════

# From twilio.com console → Account Info
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Twilio phone number (E.164 format: +1234567890)
TWILIO_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════════════════════
# OPENROUTER (AI/LLM)
# ═══════════════════════════════════════════════════════════════════════════════

# From openrouter.ai → API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (e.g. google/gemini-2.0-flash-001, anthropic/claude-3-haiku)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# OpenRouter API base URL (usually https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ═══════════════════════════════════════════════════════════════════════════════
# OUTBOUND SAFETY
# ═══════════════════════════════════════════════════════════════════════════════

# Safety gate: set to "true" to enable outbound SMS/calls
# DEFAULT: "false" (no messages sent until you explicitly enable)
OUTBOUND_ENABLED=false

# Quiet hours: auto-reply SMS suppressed 21:00-08:00 Vancouver time
# DEFAULT: "true" (quiet hours DISABLED — messages send 24/7)
# Set to "false" to re-enable quiet hours for production
QUIET_HOURS_DISABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# PORT (optional — PaaS sets this automatically)
# ═══════════════════════════════════════════════════════════════════════════════

# Port for uvicorn to listen on (default: 8000)
# Render sets this automatically — only needed for local dev
PORT=8000
