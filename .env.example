# =========================================================================
# Speed to Lead v5 — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env` to git.
# =========================================================================

# --- Twilio (all values rotated after v4 teardown) -----------------------
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=+16045551234

# --- OpenRouter (LLM, OpenAI-compatible) -------------------------------
# The engine uses the openai SDK pointed at OpenRouter. Get a key at
# https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3.5-sonnet

# --- Database -----------------------------------------------------------
# Production: PostgreSQL on Render (free tier). Render auto-injects DATABASE_URL.
# Local dev: also use PostgreSQL, or SQLite for quick tests.
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///./speed_to_lead.db

# --- Outbound safety (v5 hard rule: default = DRYRUN) -------------------
# Real SMS only when user explicitly says "enable live."
# OUTBOUND_ENABLED=true will send real Twilio SMS. Default false.
OUTBOUND_ENABLED=false
DRYRUN_TO_LOGFILE=./.tmp/sms_dryrun.log

# --- App secrets --------------------------------------------------------
SECRET_KEY=generate-a-long-random-string-here-and-paste-it
SESSION_COOKIE_SECURE=true
CSRF_SECRET=generate-another-long-random-string-here

# --- Quiet hours / staging overrides -----------------------------------
# Global kill-switch for the quiet-hours check. Leave false in prod.
QUIET_HOURS_DISABLED=false

# --- Optional: per-message staging tag (live-fire testing) -------------
MESSAGE_TAGS_ENABLED=false

# --- Scheduler ----------------------------------------------------------
# Run APScheduler inside the FastAPI lifespan, not as a separate process.
SCHEDULER_ENABLED=true
